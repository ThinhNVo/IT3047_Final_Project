@{
    ViewData["Title"] = "Home";
}

<div class="hero-section text-center py-5 my-4">
    <h1 class="display-4 fw-bold">Welcome to Hobby Hub</h1>
    <p class="lead mt-3">Track members and discover their hobbies all in one place.</p>
</div>

<div class="row g-4 justify-content-center mb-5">
    <div class="col-md-5">
        <div class="card feature-card h-100 shadow-sm">
            <div class="card-body text-center p-4">
                <h2 class="card-title h4">Members</h2>
                <p class="card-text text-muted">View, add, and manage all registered members.</p>
                <a asp-controller="Members" asp-action="Index" class="btn btn-primary mt-2">View Members</a>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card feature-card h-100 shadow-sm">
            <div class="card-body text-center p-4">
                <h2 class="card-title h4">Hobbies</h2>
                <p class="card-text text-muted">Browse, create, and manage hobbies for members.</p>
                <a asp-controller="Hobby" asp-action="Index" class="btn btn-primary mt-2">View Hobbies</a>
            </div>
        </div>
    </div>
</div>