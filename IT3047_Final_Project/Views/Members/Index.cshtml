@model IEnumerable<IT3047_Final_Project.Models.Members>

@{
    ViewData["Title"] = "Members";
}

<div class="hobby-hero text-center py-4 my-4">
    <h1 class="display-5 fw-bold">All Members</h1>
    <p class="lead mt-2">View and manage all registered members.</p>
</div>

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Add Member</a>
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Major</th>
                <th>Age</th>
                <th>Dream Job</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Major</td>
                    <td>@item.Age</td>
                    <td>@item.DreamJob</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>