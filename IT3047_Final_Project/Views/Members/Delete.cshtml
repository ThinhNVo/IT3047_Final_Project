@model IT3047_Final_Project.Models.Members

@{
    ViewData["Title"] = "Delete Member";
}

<div class="hobby-hero text-center py-4 my-4">
    <h1 class="display-5 fw-bold">Delete Member</h1>
    <p class="lead mt-2">Are you sure you want to remove this member?</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card feature-card shadow-sm p-4 text-center">
            <h4 class="mb-1">@Model.Name</h4>
            <p class="text-muted mb-1">Major: @Model.Major</p>
            <p class="text-muted mb-1">Age: @Model.Age</p>
            <p class="text-muted mb-1">Dream Job: @Model.DreamJob</p>
            <p class="text-muted mb-4">@Model.Bio</p>
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2 justify-content-center">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>